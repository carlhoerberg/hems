# TYPE topas_reactor_level gauge
topas_reactor_level <%=measurements[:reactor_level]%>
# TYPE topas_accumulation_level gauge
topas_accumulation_level <%=measurements[:accumulation_level]%>
# TYPE topas_aperformance gauge
topas_aperformance <%=measurements[:aperformance]%>
# TYPE topas_chem_percentage gauge
topas_chem_percentage <%=measurements[:chem_percentage_remaining]%>
# TYPE topas_chem_volume_remaining gauge
topas_chem_volume_remaining <%=measurements[:chem_volume_remaining]%>

# TYPE topas_total_treated_water counter
topas_total_treated_water <%=measurements[:total_treated_water]%>
# TYPE topas_average_treated_water gauge
topas_average_treated_water <%=measurements[:average_treated_water]%>
# TYPE topas_average_treated_water_reg_interval gauge
topas_average_treated_water_reg_interval <%=measurements[:average_treated_water_reg_interval]%>
# TYPE topas_max_treated_water gauge
topas_max_treated_water <%=measurements[:max_treated_water]%>
# TYPE topas_max_treated_water_10_days gauge
topas_max_treated_water_10_days <%=measurements[:max_treated_water_10_days]%>
# TYPE topas_running_time counter
topas_running_time <%=measurements[:total_running_time]%>

# TYPE topas_current_phase gauge
topas_current_phase <%=measurements[:current_phase]%>
# TYPE topas_time_of_current_phase gauge
topas_time_of_current_phase <%=measurements[:time_of_current_phase]%>

# TYPE topas_info gauge
topas_info <%=measurements[:info]%>
# TYPE topas_warning gauge
topas_warning <%=measurements[:warning]%>
# TYPE topas_emergency gauge
topas_emergency <%=measurements[:emergency]%>

# TYPE topas_temperature gauge
topas_temperature <%=status[:temperature]%>

# TYPE topas_sedimentation gauge
topas_sedimentation <%=configuration[:sedimentation]%>
# TYPE topas_excess_sludge_layer gauge
topas_excess_sludge_layer <%=configuration[:excess_sludge_layer]%>
# TYPE topas_registration_interval gauge
topas_registration_interval <%=configuration[:registration_interval]%>
# TYPE topas_pollution_coefficient gauge
topas_pollution_coefficient <%=configuration[:pollution_coefficient]%>
# TYPE topas_phosphorus_pump_performance gauge
topas_phosphorus_pump_performance <%=configuration[:phosphorus_pump_performance]%>

# TYPE metrics_gather_time gauge
metrics_gather_time{device="topas"} <%=Process.clock_gettime(Process::CLOCK_MONOTONIC) - t%>
