<html>
  <head>
    <title>Energy Management</title>
  </head>
  <body>
    <h1>Energy Management control</h1>
    <p>Aux1 mode: <%= case em.aux1_operating_mode when 0 then "Manual Off" when 1 then "Manual On" when 2 then "Auto" else "Unknown (#{em.aux1_operating_mode})" end %></p>
    <form method="post">
      <button name="action" value="aux_manual_on" <%= "disabled" if em.aux1_operating_mode == 1 %>>Aux manual on</button>
      <button name="action" value="aux_manual_off" <%= "disabled" if em.aux1_operating_mode == 0 %>>Aux manual off</button>
      <button name="action" value="aux_auto" <%= "disabled" if em.aux1_operating_mode == 2 %>>Aux auto</button>
    </form>
    <p>Active genset: <%= em.active_genset %></p>
    <form method="post">
      <button name="action" value="set_genset_gencomm" <%= "disabled" if em.active_genset == :gencomm %>>Gencomm (50A)</button>
      <button name="action" value="set_genset_sdmo" <%= "disabled" if em.active_genset == :sdmo %>>SDMO (10A)</button>
    </form>
  </body>
</html>
