# TYPE weco_soc gauge
# TYPE weco_current gauge
# TYPE weco_max_temp gauge
# TYPE weco_min_temp gauge
# TYPE weco_max_voltage gauge
# TYPE weco_min_voltage gauge
<%packs.each do |pack_id, pack|%>
<%pack[:modules].each_with_index do |m, i|%>
weco_soc{pack="<%=pack_id%>",module="<%=i%>"} <%=m[:soc_value]%>
weco_current{pack="<%=pack_id%>",module="<%=i%>"} <%=m[:current]%>
weco_max_temp{pack="<%=pack_id%>",module="<%=i%>"} <%=m[:max_tmp]%>
weco_min_temp{pack="<%=pack_id%>",module="<%=i%>"} <%=m[:min_tmp]%>
weco_max_voltage{pack="<%=pack_id%>",module="<%=i%>"} <%=m[:max_vol]%>
weco_min_voltage{pack="<%=pack_id%>",module="<%=i%>"} <%=m[:min_vol]%>
<%end%>

# TYPE weco_system_voltage gauge
weco_system_voltage{pack="<%=pack_id%>"} <%=pack[:modules][0][:sys_vol]%>

# TYPE weco_discharge_current_limit gauge
weco_discharge_current_limit{pack="<%=pack_id%>"} <%=pack[:total][:discharge_current_limit]%>

# TYPE weco_charge_current_recommended gauge
weco_charge_current_recommended{pack="<%=pack_id%>"} <%=pack[:total][:charge_current_recommended]%>

# TYPE weco_forced_state gauge
weco_forced_state{pack="<%=pack_id%>"} <%=pack[:total][:forced_state]%>

# TYPE weco_forced_seconds counter
weco_forced_seconds{pack="<%=pack_id%>"} <%=pack[:total][:forced_seconds]%>
<%end%>

# TYPE metrics_gather_time gauge
metrics_gather_time{device="weco"} <%=Process.clock_gettime(Process::CLOCK_MONOTONIC) - t%>
