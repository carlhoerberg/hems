<%devices.each do |device_id, metrics|%>
<%names = device_names[device_id] || {}%>
<%metrics.select { |_, m| m[:v] && m[:ts] / 1000 > Time.now.to_i - 3600 }.each do |key, m|%>
<%name, component = key.to_s.split("/", 2)%>
<%cn = names[component] if component%>
# TYPE <%=name%> <%=m[:counter] ? "counter" : "gauge"%>
<%=name%>{device_id="<%=device_id%>"<%=cn ? ",name=\"#{cn}\"" : ""%>} <%=m[:v]%> <%=m[:ts]%>
<%end%>
<%end%>

# TYPE metrics_gather_time gauge
metrics_gather_time{device="shelly"} <%=Process.clock_gettime(Process::CLOCK_MONOTONIC) - t%>
