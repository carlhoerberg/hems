acload_reactive_power{L="<%=l%>"} <%=next3.acload.reactive_power(l)%>
acload_total_consumed_energy{L="<%=l%>"} <%=next3.acload.total_consumed_energy(l)%>
<%next3.acload.active_warnings(l).each do |name|%>
acload_warning{L="<%=l%>",reason="<%=name%>"} 1
<%end%>
<%next3.acload.active_errors(l).each do |name|%>
acload_error{L="<%=l%>",reason="<%=name%>"} 1
<%end%>
acsource_current{L="<%=l%>"} <%=next3.acsource.current(l)%>
acsource_voltage{L="<%=l%>"} <%=next3.acsource.voltage(l)%>
acsource_reactive_power{L="<%=l%>"} <%=next3.acsource.reactive_power(l)%>
acsource_total_consumed_energy{L="<%=l%>"} <%=next3.acsource.total_consumed_energy(l)%>
<%next3.acsource.active_warnings(l).each do |name|%>
acsource_warning{L="<%=l%>",reason="<%=name%>"} 1
<%end%>
<%next3.acsource.active_errors(l).each do |name|%>
acsource_error{L="<%=l%>",reason="<%=name%>"} 1
<%end%>
<%end%>

